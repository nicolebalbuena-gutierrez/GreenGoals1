## GreenGoals environment variables
## Copy to `.env` for local dev (never commit `.env`)

# Server
PORT=3000
JWT_SECRET=replace-with-a-long-random-string

# Optional: used for AI challenge generation / chat moderation
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Sustainability news (/api/news): prefer Gemini (default model gemini-2.5-flash-lite)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Optional override if Google renames the model id:
# GEMINI_NEWS_MODEL=gemini-2.5-flash-lite

# Optional legacy: NewsAPI if GEMINI_API_KEY is not set
NEWS_API_KEY=YOUR_NEWSAPI_KEY_HERE

# Firebase Admin SDK (server-side)
# Recommended (Replit): paste the full service account JSON:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Alternative: base64 encode the JSON:
# FIREBASE_SERVICE_ACCOUNT_BASE64=BASE64_ENCODED_JSON
# Alternative: application default credentials:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
